<?xml version="1.0" encoding="UTF-8"?>
<rendertheme
    version="1"
    map-background="#F4F4F4"
    base-stroke-width="1"
    base-text-size="1">

    <!-- buildings -->
    <rule e="way" k="building" v="*">
        <area fill="#EEEEEE" />
    </rule>

    <!-- water -->
    <rule e="way" k="natural" v="water">
        <area fill="#D4E0F0" />
    </rule>

    <!-- Rivers / streams -->
    <rule e="way" k="waterway" v="river|canal">
        <line stroke="#D4E0F0" stroke-width="0.7" />
    </rule>
    <rule e="way" k="waterway" v="stream">
        <line stroke="#D4E0F0" stroke-width="0.4" />
    </rule>

    <!-- Railways -->
    <rule e="way" k="railway" v="tram">
        <line stroke="#DDDDDD" stroke-width="0.4" />
    </rule>

    <rule e="way" k="railway" v="rail">
        <line stroke="#EEEEEE" stroke-width="0.3" />
    </rule>

    <!-- Paths and steps -->
    <rule e="way" k="highway" v="path|steps">
        <line stroke="#E0E0E0" stroke-width="0.4" stroke-dasharray="3,3" />
    </rule>

    <!-- Pedestrian and track -->
    <rule e="way" k="highway" v="track">
        <line stroke="#E0E0E0" stroke-width="0.5" />
    </rule>

    <!-- Living streets and service roads -->
    <rule e="way" k="highway" v="living_street|service">
        <line stroke="#E5E5E5" stroke-width="0.7" />
        <line stroke="#FFFFFF" stroke-width="0.5" />
    </rule>

    <!-- Residential and unclassified -->
    <rule e="way" k="highway" v="residential|unclassified">
        <line stroke="#E5E5E5" stroke-width="0.8" />
        <line stroke="#FFFFFF" stroke-width="0.6" />
    </rule>

    <!-- Tertiary roads -->
    <rule e="way" k="highway" v="tertiary|tertiary_link">
        <line stroke="#E0E0E0" stroke-width="1.0" />
        <line stroke="#FFFFFF" stroke-width="0.8" />
    </rule>

    <!-- Secondary roads -->
    <rule e="way" k="highway" v="secondary|secondary_link">
        <line stroke="#DDDDDD" stroke-width="1.1" />
        <line stroke="#FFFFFF" stroke-width="0.9" />
    </rule>

    <!-- Primary roads -->
    <rule e="way" k="highway" v="primary|primary_link">
        <line stroke="#D8D8D8" stroke-width="1.3" />
        <line stroke="#FFFFFF" stroke-width="1.0" />
    </rule>

    <!-- Trunk roads -->
    <rule e="way" k="highway" v="trunk|trunk_link">
        <line stroke="#D4D4D4" stroke-width="1.4" />
        <line stroke="#FFFFFF" stroke-width="1.1" />
    </rule>

    <!-- Motorway -->
    <rule e="way" k="highway" v="motorway|motorway_link">
        <line stroke="#D0D0D0" stroke-width="1.6" />
        <line stroke="#FFFFFF" stroke-width="1.3" />
    </rule>
</rendertheme>