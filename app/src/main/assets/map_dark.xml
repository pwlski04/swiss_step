<?xml version="1.0" encoding="UTF-8"?>
<rendertheme
    version="1"
    map-background="#1A1A1A"
    base-stroke-width="1"
    base-text-size="1">

    <!-- buildings -->
    <rule e="way" k="building" v="*">
        <area fill="#202020" />
    </rule>

    <!-- water -->
    <rule e="way" k="natural" v="water">
        <area fill="#141E28" />
    </rule>

    <!-- Rivers / streams -->
    <rule e="way" k="waterway" v="river|canal">
        <line stroke="#17222D" stroke-width="0.7" />
    </rule>
    <rule e="way" k="waterway" v="stream">
        <line stroke="#131C24" stroke-width="0.4" />
    </rule>

    <!-- Railways -->
    <rule e="way" k="railway" v="tram">
        <line stroke="#2C2C2C" stroke-width="0.4" />
    </rule>

    <rule e="way" k="railway" v="rail">
        <line stroke="#222222" stroke-width="0.3" />
    </rule>

    <!-- Paths and steps -->
    <rule e="way" k="highway" v="path|steps">
        <line stroke="#262626" stroke-width="0.4" stroke-dasharray="3,3" />
    </rule>

    <!-- Pedestrian and track -->
    <rule e="way" k="highway" v="track">
        <line stroke="#262626" stroke-width="0.5" />
    </rule>

    <!-- Living streets and service roads -->
    <rule e="way" k="highway" v="living_street|service">
        <line stroke="#282828" stroke-width="0.7" />
        <line stroke="#343434" stroke-width="0.5" />
    </rule>

    <!-- Residential and unclassified -->
    <rule e="way" k="highway" v="residential|unclassified">
        <line stroke="#2B2B2B" stroke-width="0.8" />
        <line stroke="#383838" stroke-width="0.6" />
    </rule>

    <!-- Tertiary roads -->
    <rule e="way" k="highway" v="tertiary|tertiary_link">
        <line stroke="#2E2E2E" stroke-width="1.0" />
        <line stroke="#3C3C3C" stroke-width="0.8" />
    </rule>

    <!-- Secondary roads -->
    <rule e="way" k="highway" v="secondary|secondary_link">
        <line stroke="#313131" stroke-width="1.1" />
        <line stroke="#414141" stroke-width="0.9" />
    </rule>

    <!-- Primary roads -->
    <rule e="way" k="highway" v="primary|primary_link">
        <line stroke="#343434" stroke-width="1.3" />
        <line stroke="#464646" stroke-width="1.0" />
    </rule>

    <!-- Trunk roads -->
    <rule e="way" k="highway" v="trunk|trunk_link">
        <line stroke="#373737" stroke-width="1.4" />
        <line stroke="#4C4C4C" stroke-width="1.1" />
    </rule>

    <!-- Motorway -->
    <rule e="way" k="highway" v="motorway|motorway_link">
        <line stroke="#3A3A3A" stroke-width="1.6" />
        <line stroke="#525252" stroke-width="1.3" />
    </rule>
</rendertheme>
