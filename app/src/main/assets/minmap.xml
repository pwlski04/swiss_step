<?xml version="1.0" encoding="UTF-8"?>
<rendertheme
    xmlns="http://mapsforge.org/renderTheme"
    version="1"
    map-background="#F4F4F4"
    base-stroke-width="1"
    base-text-size="1">

    <!-- buildings -->
    <rule e="way" k="building" v="*">
        <area fill="#EEEEEE" />
    </rule>

    <!-- water -->
    <rule e="way" k="natural" v="water">
        <area fill="#DCEEFF" />
    </rule>

    <!-- Rivers / streams -->
    <rule e="way" k="waterway" v="river|stream|canal">
        <line stroke="#DCEEFF" stroke-width="0.8" />
    </rule>

    <!-- walkable roads -->
    <rule e="way" k="highway" v="path|pedestrian|steps|track|living_street|residential|service|unclassified|tertiary|tertiary_link">
        <line stroke="#DDDDDD" stroke-width="1.0" />
    </rule>

    <!-- drivable larger roads -->
    <rule e="way" k="highway" v="secondary|secondary_link|primary|primary_link|trunk|trunk_link">
        <line stroke="#E6E6FA" stroke-width="1.0" />
    </rule>
</rendertheme>