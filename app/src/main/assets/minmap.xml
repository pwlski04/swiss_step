<?xml version="1.0" encoding="UTF-8"?>
<rendertheme
    xmlns="http://mapsforge.org/renderTheme"
    version="1"
    map-background="#F4F4F4"
    base-stroke-width="1"
    base-text-size="1">

    <!-- buildings -->
    <rule e="way" k="building" v="*">
        <area fill="#EEEEEE" />
    </rule>

    <!-- water -->
    <rule e="way" k="natural" v="water">
        <area fill="#DCEEFF" />
    </rule>

    <!-- Rivers / streams -->
    <rule e="way" k="waterway" v="river|stream|canal">
        <line stroke="#DCEEFF" stroke-width="0.8" />
    </rule>

    <!-- Walking streets -->
    <rule e="way" k="highway" v="footway|path|pedestrian|steps|living_street|track">
        <line stroke="#DDDDDD" stroke-width="1.0" />
    </rule>

</rendertheme>